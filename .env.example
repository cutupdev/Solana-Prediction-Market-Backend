# Server
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# PostgreSQL (Prisma)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/prediction_market?schema=public

# Solana RPC (mainnet-beta | devnet | testnet | custom HTTPS URL)
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com

# On-chain program (deploy your Anchor program and set the program id)
PREDICTION_MARKET_PROGRAM_ID=YourProgramId1111111111111111111111111111111

# Optional: path to Anchor IDL JSON (defaults to ./idl/prediction_market.json if present)
# PREDICTION_MARKET_IDL_PATH=./idl/prediction_market.json

# Backend signing (only for server-side txs: crank, admin, or fee payer — keep empty if UI signs everything)
# SOLANA_AUTHORITY_SECRET_KEY=base58_or_json_array

# CORS (comma-separated origins for browser UI)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional: if set, `POST /api/v1/markets/:id/resolve` requires header `x-admin-secret`
# ADMIN_SECRET=change-me

# Rate limit (optional future use)
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=120
